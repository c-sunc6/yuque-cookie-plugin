{
  "name": "yuque-cookie-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local Yuque cookie-based CLI plugin for AI agents, without MCP or OpenAPI token.",
  "bin": {
    "yuque-local": "./bin/yuque-local.mjs"
  },
  "scripts": {
    "yuque-local": "tsx ./src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && npm run yuque-local -- --help"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pako": "^2.0.4",
    "playwright": "^1.61.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "markdown-toc": "^1.2.0",
    "node-html-parser": "^8.0.3",
    "pako": "^2.2.0",
    "vitepress": "^1.6.4"
  }
}
